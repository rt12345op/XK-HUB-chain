					Part = anchorPart
				}
			end
		end
	end,
})

Tabs.VisualTab:Toggle({
	Title = "空投 ESP",
	Value = false,
	Callback = function(v)
		State.AirDropESP = v
		if not v then
			for _, obj in pairs(espObjects.AirDrops) do
				if obj.Remove then obj:Remove() end
			end
			espObjects.AirDrops = {}
			return
		end
		
		local AirDropsFolder = GameSections:FindFirstChild("AirDrops")
		if AirDropsFolder then
			for _, heli in ipairs(AirDropsFolder:GetChildren()) do
				if heli.Name == "AirDropHeli" then
					local airdrop = heli:FindFirstChildWhichIsA("Model", true) or heli
					local hrp = airdrop:FindFirstChild("HumanoidRootPart") or airdrop.PrimaryPart
					if hrp then
						espObjects.AirDrops[airdrop] = ESP:Add({
							Entity = airdrop,
							Part = hrp,
							Name = "空投",
							Color = Color3.fromRGB(170, 0, 255),
							Highlight = true,
							Box = true,
							Text = true,
							Distance = true,
							AlwaysOnTop = true,
							StudsOffset = Vector3.new(0, 5, 0),
						})
					end
				end
			end
		end
	end,
})

--// =========================================================
--// ==================== 「蓝图」标签页 =======================
--// =========================================================

Tabs.BlueprintTab:Section({ Title = "蓝图系统" })

Tabs.BlueprintTab:Button({
	Title = "解锁除魔法书外所有蓝图",
	Callback = function()
		unlockAllBlueprintsExceptMagicBook()
		WindUI:Notify({
			Title = "蓝图已解锁",
			Content = "除魔法书外的所有蓝图已解锁",
			Duration = 3,
			Icon = "check-circle"
		})
	end,
})

Tabs.BlueprintTab:Toggle({
	Title = "自动解锁新蓝图",
	Value = false,
	Callback = function(v)
		State.AutoUnlockBlueprints = v
		if v then
			autoUnlockBlueprintsExceptMagicBook()
			WindUI:Notify({
				Title = "自动解锁已开启",
				Content = "新蓝图将自动解锁（魔法书除外）",
				Duration = 3,
				Icon = "check-circle"
			})
		else
			for _, conn in ipairs(blueprintConnections) do
				conn:Disconnect()
			end
			blueprintConnections = {}
			WindUI:Notify({
				Title = "自动解锁已关闭",
				Content = "新蓝图将不再自动解锁",
				Duration = 3,
				Icon = "info"
			})
		end
	end,
})

